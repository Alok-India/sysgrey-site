---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sysgrey Technologies">
  <nav style="background: var(--color-secondary); padding: 1rem; position: sticky; top: 0; z-index: 100;">
    <div style="max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center;">
      <h1 style="margin: 0; font-size: 1.5rem;">Sysgrey</h1>
      <ul style="list-style: none; display: flex; gap: 2rem;">
        <li><a href="#hero">Home</a></li>
        <li><a href="#solutions">Solutions</a></li>
        <li><a href="#leadership">Leadership</a></li>
        <li><a href="#clients">Clients</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </div>
  </nav>

  <!-- Hero Section -->
  <section id="hero" style="padding: 6rem 2rem; text-align: center; background: linear-gradient(135deg, var(--color-secondary), var(--color-accent));">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h1 style="font-size: 3.5rem; margin-bottom: 1rem; color: var(--color-highlight);">Sysgrey Technologies</h1>
      <p style="font-size: 1.3rem; color: var(--color-text-light); margin-bottom: 2rem;">Building robust IT solutions for enterprise success</p>
      <button>Get Started</button>
    </div>
  </section>

  <!-- Solutions Section (Placeholder) -->
  <section id="solutions" style="padding: 4rem 2rem; background: var(--color-primary);">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 style="font-size: 2.5rem; text-align: center; margin-bottom: 3rem;">Our Solutions</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem;">
        <div style="background: var(--color-secondary); padding: 2rem; border-radius: 8px;">
          <h3>Managed IT Services</h3>
          <p>Comprehensive IT infrastructure management and support</p>
        </div>
        <div style="background: var(--color-secondary); padding: 2rem; border-radius: 8px;">
          <h3>Cybersecurity</h3>
          <p>Enterprise-grade security solutions and threat management</p>
        </div>
        <div style="background: var(--color-secondary); padding: 2rem; border-radius: 8px;">
          <h3>Business Process Automation</h3>
          <p>Streamline operations with intelligent automation</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Leadership Section (Placeholder) -->
  <section id="leadership" style="padding: 4rem 2rem; background: var(--color-secondary);">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 style="font-size: 2.5rem; text-align: center; margin-bottom: 3rem;">Leadership</h2>
      <p style="text-align: center; color: var(--color-text-light);">Leadership team content coming soon...</p>
    </div>
  </section>

  <!-- Clients Section (Placeholder) -->
  <section id="clients" style="padding: 4rem 2rem; background: var(--color-primary);">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 style="font-size: 2.5rem; text-align: center; margin-bottom: 3rem;">Our Clients</h2>
      <p style="text-align: center; color: var(--color-text-light);">Client logos and testimonials coming soon...</p>
    </div>
  </section>

  <!-- Contact Section (Placeholder) -->
  <section id="contact" style="padding: 4rem 2rem; background: var(--color-secondary);">
    <div style="max-width: 1200px; margin: 0 auto; text-align: center;">
      <h2 style="font-size: 2.5rem; margin-bottom: 2rem;">Get In Touch</h2>
      <p style="color: var(--color-text-light); margin-bottom: 2rem;">Contact information and form coming soon...</p>
    </div>
  </section>

  <!-- Footer -->
  <footer style="background: var(--color-accent); padding: 2rem; text-align: center; border-top: 2px solid var(--color-highlight);">
    <p>&copy; 2026 Sysgrey Technologies. All rights reserved.</p>
  </footer>
</Layout>
